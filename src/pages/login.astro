---
import Button from "@/components/Button/Button.astro";
import Card from "@/components/Card/Card.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Entrar como organizador | Secret Sánchez">
  <main>
    <div class="page-shell login-page">
      <section class="login-page__hero">
        <p>Organizador familiar</p>
        <h1>Entrar como organizador</h1>
        <p>
          Escribe tu email y te enviaremos un enlace seguro para entrar. La sesión queda guardada para que no tengas
          que repetirlo cada vez.
        </p>
      </section>

      <Card tone="accent">
        <form class="login-page__form" id="magic-link-form">
          <label class="form-field">
            Email
            <input class="input" name="email" type="email" placeholder="juan@email.com" required />
          </label>
          <Button type="submit" size="large">Enviarme enlace de acceso</Button>
          <p class="login-page__message" id="login-message" role="status"></p>
        </form>
      </Card>
    </div>
  </main>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>("#magic-link-form");
  const message = document.querySelector<HTMLElement>("#login-message");

  if (form && message) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const data = new FormData(form);
      message.textContent = "Enviando enlace...";

      const response = await fetch("/api/auth/magic-link", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: data.get("email") })
      });
      const payload = (await response.json()) as { message: string };
      message.textContent = payload.message;
    });
  }
</script>

<style>
  .login-page {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 440px);
    gap: var(--space-xl);
    align-items: center;
    min-height: calc(100vh - 96px);
  }

  .login-page__hero {
    display: grid;
    gap: var(--space-lg);
    padding: clamp(2rem, 5vw, 4rem);
    color: white;
    background:
      linear-gradient(135deg, rgba(127, 29, 29, 0.9), rgba(184, 50, 50, 0.78)),
      url("https://images.unsplash.com/photo-1543589077-47d81606c1bf?auto=format&fit=crop&w=1600&q=80");
    background-position: center;
    background-size: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
  }

  .login-page__hero p {
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.08rem;
  }

  .login-page__form {
    display: grid;
    gap: var(--space-lg);
  }

  .login-page__message {
    min-height: 1.5rem;
    font-weight: 800;
  }

  @media (max-width: 780px) {
    .login-page {
      grid-template-columns: 1fr;
    }
  }
</style>
